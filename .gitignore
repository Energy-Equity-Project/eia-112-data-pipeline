# Per-repo Claude context (local only, not committed)
CLAUDE.md

# Data files — shared data lives only in Data/ and Cleaned_Data/, never committed
*.csv
*.xlsx

# Scratch / generated — ignore contents but keep the empty dirs (via .gitkeep below)
outputs/*
temp/*

# R session / project artifacts
.Rproj.user
.Rhistory
.RData
.Ruserdata
.Renviron
.env

# OS
.DS_Store

# Committed reference inputs (EEP-determined ownership + bad-data flags) — exceptions to the *.csv rule
!data/eia-112-manual-ownership-overrides.csv
!data/eia-112-manual-bad-data-flags.csv

# Keep empty scratch dirs tracked
!outputs/.gitkeep
!temp/.gitkeep
